{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/challenges/[id]/complete",
      "regex": "^/api/challenges/([^/]+?)/complete(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/challenges/(?<nxtPid>[^/]+?)/complete(?:/)?$"
    },
    {
      "page": "/api/comments/[id]/upvote",
      "regex": "^/api/comments/([^/]+?)/upvote(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/comments/(?<nxtPid>[^/]+?)/upvote(?:/)?$"
    },
    {
      "page": "/api/connections/[id]",
      "regex": "^/api/connections/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/connections/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/routes/[id]",
      "regex": "^/api/routes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/routes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/routes/[id]/stops",
      "regex": "^/api/routes/([^/]+?)/stops(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/routes/(?<nxtPid>[^/]+?)/stops(?:/)?$"
    },
    {
      "page": "/api/stops/[id]",
      "regex": "^/api/stops/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/stops/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/terminals/[id]",
      "regex": "^/api/terminals/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/terminals/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/terminals/[id]/comments",
      "regex": "^/api/terminals/([^/]+?)/comments(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/terminals/(?<nxtPid>[^/]+?)/comments(?:/)?$"
    },
    {
      "page": "/api/terminals/[id]/history",
      "regex": "^/api/terminals/([^/]+?)/history(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/terminals/(?<nxtPid>[^/]+?)/history(?:/)?$"
    },
    {
      "page": "/api/users/[id]",
      "regex": "^/api/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/users/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/privacy",
      "regex": "^/privacy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy(?:/)?$"
    },
    {
      "page": "/status",
      "regex": "^/status(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/status(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}